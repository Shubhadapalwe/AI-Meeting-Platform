# ── Network (set Mac's WiFi IP so Android can connect) ───────────────────────
# Find it with: ipconfig getifaddr en0
HOST_IP=192.168.1.xxx

# LiveKit via Vite proxy — wss://IP:5173/livekit → ws://livekit:7880 internally
# Updated automatically by start.sh — you normally don't need to touch this
LIVEKIT_PUBLIC_URL=wss://192.168.1.xxx:5173/livekit

# ── Sarvam AI — BEST for Indian languages (Hindi/Marathi/English/Hinglish) ───
# Covers: transcription + speaker diarization + AI summary (Sarvam-M)
# Sign up FREE at: https://dashboard.sarvam.ai → API Keys
SARVAM_API_KEY=sk_...

# ── AssemblyAI — fallback diarization (FREE 100 hrs/month) ───────────────────
# Get key at: https://www.assemblyai.com → Account → API Keys
ASSEMBLYAI_API_KEY=

# ── Gemini — fallback AI summary (FREE) ──────────────────────────────────────
# Get key at: https://aistudio.google.com → Get API Key
GEMINI_API_KEY=

# ── OpenAI (optional — best quality summaries) ───────────────────────────────
# OPENAI_API_KEY=sk-...

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# For Gmail: enable 2FA, then create an App Password at:
#   https://myaccount.google.com/apppasswords
#
# Without SMTP config, the platform runs in dry-run mode:
# emails are saved to backend/storage/email_logs/ but not sent.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM=you@gmail.com
